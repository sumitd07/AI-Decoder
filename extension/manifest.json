{
  "manifest_version": 3,
  "name": "Decoder — AI terms, explained in place",
  "version": "1.0.1",
  "description": "Highlights AI jargon on any page. Click a term to understand it in seconds and save it to your cheatsheet.",
  "permissions": ["storage", "scripting", "identity"],
  "host_permissions": ["https://*.supabase.co/*"],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Decoder — my cheatsheet",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  }
}
